install.packages(c("sf", "tidyverse"))
gpklink="Americas_Mobiles.gpkg"
#jsonlink=
library(sf)
map1=read_sf(gpklink, layer = "ddm")
library(ggplot2)
map1gg=ggplot() + theme_bw() + geom_sf(data = map1,fill='red', color='grey90')
map1gg
View(map1)
saveRDS(map1gg,file='map1.rds')
map2=read_sf(gpklink, layer = "psm")
map2gg=ggplot() + theme_void() + geom_sf(data = map2,
aes(size=size))
map2gg
saveRDS(map2gg,file='map2.rds')
map3=read_sf(gpklink, layer = "coropleth")
View(map3)
map3gg=ggplot() + theme_void() + geom_sf(data = map3,
aes(fill=as.ordered(mobiles_cat)))
map3gg
saveRDS(map2gg,file='map3.rds')
